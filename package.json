{
  "name": "ezeo",
  "version": "0.3.0",
  "description": "Ezeo AI CLI — Talk to your SEO data",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "ezeo": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build && npm test",
    "test:watch": "vitest",
    "lint:fix": "eslint src/ --fix"
  },
  "keywords": [
    "seo",
    "geo",
    "ai",
    "cli",
    "ezeo"
  ],
  "author": "JAMAK AI <contacto@jamak.com.mx>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joseamijares/ezeo-cli.git"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.101.0",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "conf": "^15.1.0",
    "inquirer": "^13.3.2",
    "openai": "^6.32.0",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^9.39.4",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.1"
  }
}
