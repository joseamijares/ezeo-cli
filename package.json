{
  "name": "ezeo",
  "version": "0.2.0",
  "description": "Ezeo AI CLI — Talk to your SEO data",
  "type": "module",
  "bin": {
    "ezeo": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build",
    "test:watch": "vitest",
    "lint:fix": "eslint src/ --fix"
  },
  "keywords": [
    "seo",
    "geo",
    "ai",
    "cli",
    "ezeo"
  ],
  "author": "JAMAK AI <contacto@jamak.com.mx>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joseamijares/ezeo-cli.git"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@supabase/supabase-js": "^2.49.4",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "conf": "^15.1.0",
    "inquirer": "^12.4.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^9.39.4",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
